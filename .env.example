# First Session extractor — environment configuration.
# Copy to ".env" and fill in your values. NEVER commit the real .env.

# Required for Gemini enrichment. Without it the script still extracts, but skips
# enrichment (enrichment UX fields stay empty).
GEMINI_API_KEY=your-gemini-api-key-here

# Optional. Overrides the default model preference.
# Default order if unset: gemini-3.1-flash-lite -> gemini-3-flash-preview
# GEMINI_MODEL=gemini-3.1-flash-lite
